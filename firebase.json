{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/product/**",
        "destination": "/src/product.html"
      },
      {
        "source": "/admin/**",
        "destination": "/src/admin/**"
      }
    ],
    "headers": [
      {
        "source": "/assets/**/*.@(jpg|jpeg|gif|png|svg|webp|css|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  }
}